{
  "name": "prompt-regression",
  "version": "0.1.0",
  "description": "Snapshot testing for LLM prompts — catch prompt & model regressions before you ship.",
  "keywords": [
    "llm",
    "prompt",
    "regression",
    "snapshot-testing",
    "eval",
    "ci",
    "anthropic",
    "openai",
    "cli"
  ],
  "author": "Keith Lindsay (https://github.com/keithalindsay)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "prompt-regression": "dist/cli.js",
    "pr": "dist/cli.js"
  },
  "files": [
    "dist",
    "DESIGN.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keithalindsay/prompt-regression.git"
  },
  "bugs": {
    "url": "https://github.com/keithalindsay/prompt-regression/issues"
  },
  "homepage": "https://github.com/keithalindsay/prompt-regression#readme"
}
